# Riot API 키 (https://developer.riotgames.com 에서 발급)
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 데이터베이스 (개발은 SQLite, 배포 시 PostgreSQL URL로 교체)
DATABASE_URL=sqlite:///./tft.db

# 6시간마다 자동 수집 여부
ENABLE_SCHEDULER=false

# 수집 파라미터 (개발 키 rate limit 고려)
COLLECT_SUMMONER_COUNT=40
COLLECT_MATCHES_PER_SUMMONER=8
MIN_SAMPLE_SIZE=20
